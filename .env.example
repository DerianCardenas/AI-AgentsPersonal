# ══════════════════════════════════════════════════════════════
# .env.example — Copia como .env y configura tus valores
# NUNCA subas .env al repositorio (está en .gitignore)
# ══════════════════════════════════════════════════════════════

# ─── Rutas base ───────────────────────────────────────────────
AGENTS_ROOT=/ruta/absoluta/a/AgentsPersonal

# ─── Modelos LLM ───────────────────────────────────────────────
# ELIGE UNA OPCIÓN (descomenta la que uses)

## OPCIÓN 1: APIs Externas (requiere créditos)
# MODEL_PO=claude-opus-4-6
# MODEL_SCRUM=claude-opus-4-6
# MODEL_DBA=gemini-2.5-pro
# MODEL_BACKEND=gemini-2.5-pro
# MODEL_FRONTEND=gemini-2.5-pro
# MODEL_TESTER=gemini-2.5-flash
# MODEL_DOCS=gemini-2.5-flash

## OPCIÓN 2: Ollama Local (RECOMENDADO - gratis, requiere GPU)
MODEL_PO=ollama:mistral
MODEL_SCRUM=ollama:mistral
MODEL_DBA=ollama:mistral
MODEL_BACKEND=ollama:mistral
MODEL_FRONTEND=ollama:mistral
MODEL_TESTER=ollama:mistral
MODEL_DOCS=ollama:mistral

## OPCIÓN 3: Ollama Remoto (equipo gaming como servidor)
# MODEL_PO=http://192.168.1.100:11434
# MODEL_SCRUM=http://192.168.1.100:11434
# MODEL_DBA=http://192.168.1.100:11434
# MODEL_BACKEND=http://192.168.1.100:11434
# MODEL_FRONTEND=http://192.168.1.100:11434
# MODEL_TESTER=http://192.168.1.100:11434
# MODEL_DOCS=http://192.168.1.100:11434

# Configuración Ollama local (opcional)
# OLLAMA_BASE_URL=http://localhost:11434

# ─── API Keys (SOLO si usas APIs Externas) ────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
BRAVE_API_KEY=

# ══════════════════════════════════════════════════════════════
# PROYECTOS
# ══════════════════════════════════════════════════════════════

# ─── Proyecto: SAASFINANCIAL ──────────────────────────────────
SAASFINANCIAL_BACK=/ruta/absoluta/05-SaaSFinancial/Backend
SAASFINANCIAL_FRONT=/ruta/absoluta/05-SaaSFinancial/Frontend
SAASFINANCIAL_DB=/ruta/absoluta/05-SaaSFinancial/BD
SAASFINANCIAL_TEST=/ruta/absoluta/05-SaaSFinancial/Test
SAASFINANCIAL_POSTGRES=postgresql://usuario:password@localhost:5432/saasfinancial_dev

# ─── Proyecto: ECOMMERCE ──────────────────────────────────────
ECOMMERCE_BACK=/ruta/absoluta/06-Ecommerce/Backend
ECOMMERCE_FRONT=/ruta/absoluta/06-Ecommerce/Frontend
ECOMMERCE_DB=/ruta/absoluta/06-Ecommerce/BD
ECOMMERCE_TEST=/ruta/absoluta/06-Ecommerce/Test
ECOMMERCE_POSTGRES=postgresql://usuario:password@localhost:5432/ecommerce_dev

# ══════════════════════════════════════════════════════════════
# NOTAS
# ══════════════════════════════════════════════════════════════

# 1. Modelos soportados:
#    - claude-*, gemini-*, gpt-*   → APIs externas
#    - ollama:mistral              → Ollama local
#    - http://IP:11434             → Ollama remoto

# 2. Para Ollama local (GRATIS):
#    1. Instala: https://ollama.ai
#    2. Ejecuta: ollama pull mistral
#    3. Corre: ollama serve
#    4. Usa: MODEL_*=ollama:mistral

# 3. Para Ollama remoto (equipo gaming):
#    1. Ollama corre en gaming: ollama serve
#    2. Obtén IP: ipconfig (Windows) o hostname -I (Linux/Mac)
#    3. Usa: MODEL_*=http://192.168.1.100:11434
#    4. Reemplaza 192.168.1.100 con la IP real

# 4. Las rutas DEBEN SER ABSOLUTAS:
#    ❌ ./Backend
#    ✅ /home/usuario/proyectos/Backend

# 5. PostgreSQL: configura credenciales y BD
#    El agente DBA las crea si no existen
