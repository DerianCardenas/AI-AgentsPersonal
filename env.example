# ─────────────────────────────────────────
# AI-Agents — Variables de entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas el .env real al repositorio
# ─────────────────────────────────────────

# ─── LLM Providers ───────────────────────
# Al menos uno es obligatorio

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── MCP: GitHub ─────────────────────────
# github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Scopes necesarios: repo, read:org

GITHUB_PERSONAL_ACCESS_TOKEN=

# ─── MCP: Brave Search ───────────────────
# brave.com/search/api → plan gratuito: 2,000 consultas/mes

BRAVE_API_KEY=

# ─── MCP: PostgreSQL ─────────────────────
# Una connection string por proyecto si manejas múltiples BDs
# Formato: postgresql://usuario:password@host:puerto/nombre_bd

POSTGRES_CONNECTION_STRING=

# ─── Paths ───────────────────────────────
# Ruta absoluta donde viven tus proyectos
# Ejemplo: /home/derian/projects

PROJECTS_ROOT=
AGENTS_ROOT=

# ─── Configuración del orquestador ───────
# Modelo por defecto si no se especifica en el agente

DEFAULT_MODEL=claude-sonnet-4-5
