# ══════════════════════════════════════════════════════════════
# AI-Agents — Variables de entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el .env al repositorio — está en .gitignore
# ══════════════════════════════════════════════════════════════

# ─── Rutas base ───────────────────────────────────────────────
# Rutas absolutas en tu máquina
# Ejemplo: /home/derian/agents  o  /Users/derian/agents

AGENTS_ROOT=/ruta/absoluta/a/esta/carpeta/agents
PROJECTS_ROOT=/ruta/absoluta/a/tu/carpeta/de/proyectos

# ─── API Keys ─────────────────────────────────────────────────

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
BRAVE_API_KEY=

# ─── Modelos por agente ───────────────────────────────────────
# Puedes usar cualquier modelo de cualquier proveedor
#
# Anthropic: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
# Google:    gemini-2.5-pro  | gemini-2.5-flash  | gemini-2.5-flash-lite
# OpenAI:    gpt-5.4         | gpt-5.4-mini      | gpt-4.1
#
# El proveedor se detecta automáticamente por el prefijo del nombre:
#   claude-* → Anthropic | gemini-* → Google | gpt-* → OpenAI

MODEL_PO=claude-opus-4-6
MODEL_SCRUM=claude-opus-4-6
MODEL_DBA=gemini-2.5-pro
MODEL_BACKEND=gemini-2.5-pro
MODEL_FRONTEND=gemini-2.5-pro
MODEL_TESTER=gemini-2.5-flash
MODEL_DOCS=gemini-2.5-flash

# ══════════════════════════════════════════════════════════════
# PROYECTOS
# Agrega un bloque por cada proyecto que manejes
# Copia el bloque y reemplaza NOMBRE_PROYECTO con el nombre real
# ══════════════════════════════════════════════════════════════

# ─── Proyecto: NOMBRE_PROYECTO_1 ──────────────────────────────

NOMBRE_PROYECTO_1_BACK=/ruta/absoluta/back-repo
NOMBRE_PROYECTO_1_FRONT=/ruta/absoluta/front-repo
NOMBRE_PROYECTO_1_DB=/ruta/absoluta/db-repo
NOMBRE_PROYECTO_1_TEST=/ruta/absoluta/test-repo
NOMBRE_PROYECTO_1_POSTGRES=postgresql://usuario:password@localhost:5432/nombre_bd

# ─── Proyecto: NOMBRE_PROYECTO_2 ──────────────────────────────

NOMBRE_PROYECTO_2_BACK=/ruta/absoluta/back-repo
NOMBRE_PROYECTO_2_FRONT=/ruta/absoluta/front-repo
NOMBRE_PROYECTO_2_DB=/ruta/absoluta/db-repo
NOMBRE_PROYECTO_2_TEST=/ruta/absoluta/test-repo
NOMBRE_PROYECTO_2_POSTGRES=postgresql://usuario:password@localhost:5432/nombre_bd

# Agrega más proyectos siguiendo el mismo patrón...
